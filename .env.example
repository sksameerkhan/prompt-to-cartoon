# Copy this file to .env.local and fill in your own values.
# None of these cost money at the free tiers described in README.md

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key

# WhatsApp number shown to users when they run out of credits (with country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567
